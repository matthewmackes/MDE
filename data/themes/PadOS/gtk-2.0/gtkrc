# PadOS — GTK 2 backwards-compat (for older apps that still query GTK2).
# Mirrors the GTK3 Carbon Gray 100 palette.

gtk-color-scheme = "bg_color:#161616\nfg_color:#f4f4f4\nbase_color:#262626\ntext_color:#f4f4f4\nselected_bg_color:#0f62fe\nselected_fg_color:#ffffff\ntooltip_bg_color:#525252\ntooltip_fg_color:#f4f4f4"

style "default" {
    GtkButton::default_border        = { 0, 0, 0, 0 }
    GtkButton::child_displacement_x  = 0
    GtkButton::child_displacement_y  = 0
    GtkButton::focus_padding         = 1
    GtkButton::inner_border          = { 8, 8, 4, 4 }
    GtkCheckButton::indicator_size   = 14
    GtkEntry::inner-border           = { 6, 6, 4, 4 }
    GtkScrolledWindow::scrollbar_spacing  = 0
    GtkScrolledWindow::scrollbars_within_bevel = 1
    xthickness = 1
    ythickness = 1
    fg[NORMAL]      = @fg_color
    fg[PRELIGHT]    = @fg_color
    fg[SELECTED]    = @selected_fg_color
    fg[ACTIVE]      = @fg_color
    fg[INSENSITIVE] = darker(@bg_color)
    bg[NORMAL]      = @bg_color
    bg[PRELIGHT]    = shade(1.10, @bg_color)
    bg[SELECTED]    = @selected_bg_color
    bg[ACTIVE]      = shade(1.05, @bg_color)
    bg[INSENSITIVE] = @bg_color
    base[NORMAL]    = @base_color
    base[PRELIGHT]  = @base_color
    base[SELECTED]  = @selected_bg_color
    base[ACTIVE]    = @base_color
    base[INSENSITIVE] = darker(@base_color)
    text[NORMAL]    = @text_color
    text[PRELIGHT]  = @text_color
    text[SELECTED]  = @selected_fg_color
    text[ACTIVE]    = @text_color
    text[INSENSITIVE] = mix(0.50, @bg_color, @fg_color)
}

class "GtkWidget" style "default"
